# Supabase — dapatkan dari: https://app.supabase.com -> Settings -> API

# Project URL (aman untuk diekspos ke client)
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co

# Anon Key — untuk akses publik dengan RLS aktif (aman untuk diekspos ke client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Service Role Key — untuk akses server-side penuh (RAHASIA, jangan ekspos ke client!)
# Digunakan di: Server Actions, admin actions, bypass RLS
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>
